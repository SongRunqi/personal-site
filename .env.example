# 复制为 .env 后填写(docker compose 会自动读取)
SITE_BASE_URL=https://example.com
# 数据库密码,生成一个:openssl rand -hex 16(不要包含空格和引号)
POSTGRES_PASSWORD=please-change-me-4f2a9c

# GitHub OAuth App(Settings → Developer settings → OAuth Apps)
# 回调地址填:https://example.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 允许登录的 GitHub 账号(即站长本人;逗号可分隔多个)
ADMIN_GITHUB_LOGINS=SongRunqi
ADMIN_EMAILS=yitiansong4@gmail.com
